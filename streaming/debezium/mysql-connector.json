{
  "name": "scholarpath-mysql-cdc",
  "config": {
    "connector.class": "io.debezium.connector.mysql.MySqlConnector",
    "database.hostname": "mysql.scholarpath.svc",
    "database.port": "3306",
    "database.user": "debezium",
    "database.password": "${file:/secrets/debezium-mysql.password:password}",
    "database.server.id": "184054",
    "topic.prefix": "scholarpath.mysql",
    "schema.history.internal.kafka.bootstrap.servers": "kafka.scholarpath.svc:9092",
    "schema.history.internal.kafka.topic": "scholarpath.mysql.schema-history"
  }
}
