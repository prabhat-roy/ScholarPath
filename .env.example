# ============================================================
# Project-wide local development environment.
# Copy to .env and adjust per developer.
# .env is gitignored - never commit real credentials.
# ============================================================

# ----- General -----
ENV=development
LOG_LEVEL=debug
SERVICE_DOMAIN=localhost

# ----- PostgreSQL (primary transactional store) -----
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=app
POSTGRES_PASSWORD=app
POSTGRES_DB=app

# ----- MongoDB (course content, assignments, submissions) -----
MONGO_URI=mongodb://localhost:27017
MONGO_DB=app

# ----- Redis (sessions, classroom state, leaderboards) -----
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ----- Cassandra (xAPI / SCORM event archive) -----
CASSANDRA_CONTACT_POINTS=localhost
CASSANDRA_KEYSPACE=scholarpath_xapi

# ----- Elasticsearch (search across courses, content, library) -----
ELASTICSEARCH_URL=http://localhost:9200

# ----- Neo4j (adaptive learning knowledge graph) -----
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=scholarpath

# ----- Kafka (domain events) -----
KAFKA_BROKERS=localhost:9092
KAFKA_SCHEMA_REGISTRY=http://localhost:8081

# ----- NATS JetStream (live classroom signalling) -----
NATS_URL=nats://localhost:4222

# ----- Object storage (MinIO / S3 - course videos, recordings) -----
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=scholarpath

# ----- OpenTelemetry -----
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAMESPACE=scholarpath-local

# ----- Auth (Keycloak / OIDC) -----
OIDC_ISSUER_URL=http://localhost:8080/realms/scholarpath
OIDC_CLIENT_ID=scholarpath
OIDC_CLIENT_SECRET=change-me

# ----- LTI 1.3 -----
LTI_PLATFORM_ISSUER=https://lti.scholarpath.local
LTI_KEYSET_URL=http://localhost:50026/.well-known/jwks.json

# ----- xAPI / Learning Record Store -----
XAPI_LRS_ENDPOINT=http://localhost:50263/xapi
XAPI_AUTH=Basic Y2hhbmdlOmNoYW5nZQ==

# ----- Vault -----
VAULT_ADDR=http://localhost:8200
VAULT_TOKEN=root

# ----- Feature flags (Unleash) -----
UNLEASH_URL=http://localhost:4242/api
UNLEASH_API_TOKEN=

# ----- Observability backends -----
PROMETHEUS_URL=http://localhost:9090
GRAFANA_URL=http://localhost:3001
LOKI_URL=http://localhost:3100
JAEGER_URL=http://localhost:16686

# ----- COPPA / FERPA -----
COPPA_PARENTAL_CONSENT_REQUIRED=true
FERPA_DIRECTORY_INFO_OPT_OUT_DEFAULT=false
